// Tulsi.store — core commerce schema.
// PostgreSQL. Prices are stored as integer cents in EUR (base currency);
// display currencies are converted at the edge, never persisted per-product.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URL lives in prisma.config.ts (Prisma 7 convention).
datasource db {
  provider = "postgresql"
}

enum Supplier {
  BIGBUY
  CJDROPSHIPPING
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  FORWARDED_TO_SUPPLIER
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum SupplierOrderStatus {
  QUEUED
  PLACED
  ACCEPTED
  SHIPPED
  DELIVERED
  FAILED
}

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  sortOrder    Int                   @default(0)
  products     Product[]
  translations CategoryTranslation[]
  createdAt    DateTime              @default(now())
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Product {
  id                String               @id @default(cuid())
  slug              String               @unique
  sku               String               @unique
  supplier          Supplier
  supplierProductId String // ID/reference at BigBuy or CJ, used for sync + ordering
  categoryId        String
  priceCents        Int // retail price, EUR cents
  compareAtCents    Int?
  costCents         Int // supplier cost, EUR cents — margin = price - cost
  stock             Int                  @default(0)
  images            String[]
  active            Boolean              @default(true)
  category          Category             @relation(fields: [categoryId], references: [id])
  translations      ProductTranslation[]
  orderItems        OrderItem[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([categoryId, active])
  @@index([supplier, supplierProductId])
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  locale      String
  name        String
  tagline     String
  description String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model Order {
  id              String          @id @default(cuid())
  number          String          @unique // human-readable, e.g. TLS-2026-000123
  email           String
  locale          String          @default("en")
  currency        String          @default("EUR")
  status          OrderStatus     @default(PENDING_PAYMENT)
  subtotalCents   Int
  shippingCents   Int             @default(0)
  totalCents      Int
  stripeSessionId String?         @unique
  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingPostal  String?
  shippingCountry String?
  items           OrderItem[]
  supplierOrders  SupplierOrder[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  name       String // snapshot at purchase time
  quantity   Int
  unitCents  Int
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])
}

// One order can fan out to several suppliers; each leg is tracked separately.
model SupplierOrder {
  id              String              @id @default(cuid())
  orderId         String
  supplier        Supplier
  status          SupplierOrderStatus @default(QUEUED)
  externalOrderId String? // order ID at the supplier
  trackingNumber  String?
  trackingUrl     String?
  lastError       String?
  raw             Json? // last raw supplier payload, for debugging
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplier, status])
}

// ── Plataforma de Astrología Védica (pivote 2026-07) ─────────────────────────
// Solicitudes de horóscopo. Flujo: el cliente envía sus datos → PENDING →
// el admin envía manualmente un enlace PayPal → PAYMENT_SENT → el cliente
// paga → PAID → los eruditos preparan el informe → IN_PROGRESS → PDF por
// email en <24h → COMPLETED. Sin pasarela automática por diseño.

enum HoroscopeStatus {
  PENDING
  PAYMENT_SENT
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model HoroscopeRequest {
  id           String          @id @default(cuid())
  fullName     String
  email        String
  birthDate    String // YYYY-MM-DD tal como lo escribe el cliente
  birthTime    String? // HH:MM local; null = no conoce su hora exacta
  timeUnknown  Boolean         @default(false)
  city         String
  country      String
  comments     String?
  locale       String          @default("en")
  status       HoroscopeStatus @default(PENDING)
  adminNotes   String?
  paymentSentAt DateTime?
  paidAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

// Suscriptores de newsletter (formulario de la home; RGPD: consentimiento
// explícito registrado; doble opt-in se activará junto con Resend).
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  consent   Boolean  @default(true)
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Structured operational log surfaced in the admin panel.
model ApiLog {
  id        String   @id @default(cuid())
  source    String // "bigbuy" | "cj" | "stripe" | "system"
  level     String // "info" | "warn" | "error"
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([source, createdAt])
}
